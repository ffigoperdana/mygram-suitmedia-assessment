# MyGram fullstack environment template
# Copy to .env for local Docker Compose. Put production values in Coolify secrets.

# Backend application
PORT=8080
API_PORT=8080
GIN_MODE=debug
JWT_SECRET=replace-with-a-random-32-plus-character-secret
JWT_EXPIRATION_HOURS=24
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://mygram.example.com
PUBLIC_OPENAPI_ENABLED=true
# Options: internal, public, disabled. Use public or disabled in production.
SWAGGER_UI_MODE=internal

# Optional bootstrap accounts. Leave blank in production unless you want the app
# to create/update these accounts on startup for first-login testing.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_AGE=21
BOOTSTRAP_USER_EMAIL=
BOOTSTRAP_USER_USERNAME=
BOOTSTRAP_USER_PASSWORD=
BOOTSTRAP_USER_AGE=18

# Redis cache and distributed rate limiting. Enable for the fullstack Compose
# stack or another environment where Redis is reachable.
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=60
RATE_LIMIT_REQUESTS=120
AUTH_RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# S3-compatible object storage, for example Garage on Coolify
S3_ENDPOINT=https://s3.fgdev.tech
S3_REGION=garage
S3_BUCKET=fgdev-media
S3_ACCESS_KEY_ID=replace-with-garage-access-key
S3_SECRET_ACCESS_KEY=replace-with-garage-secret-key
S3_FORCE_PATH_STYLE=true
# Optional. In production, prefer the same-origin media proxy:
# S3_PUBLIC_BASE_URL=https://mygram.fgdev.tech/media
S3_PUBLIC_BASE_URL=
S3_UPLOAD_MAX_MB=4

# Self-hosted Web Push notifications
# Generate keys with: go run ./cmd/vapidkeys
PUSH_NOTIFICATIONS_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID_SUBJECT identifies this app to browser push services. A mailto: value is
# allowed by the Web Push spec, but it is not an email recipient and MyGram does
# not send SMTP/email notifications.
VAPID_SUBJECT=mailto:admin@example.com

# PostgreSQL
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=replace-with-a-strong-password
DB_NAME=finalproject
DB_PORT=5432
DB_SSLMODE=disable

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
VITE_USE_SAME_ORIGIN_API=false
# Leave empty in production to use the frontend same-origin /api proxy.
PUBLIC_API_BASE_URL=

# Container registry and deployment
DOCKER_REGISTRY=ghcr.io
GITHUB_REPOSITORY=your-github-username/mygram
IMAGE_TAG=latest
BACKEND_IMAGE=ghcr.io/your-github-username/mygram-api:latest
FRONTEND_IMAGE=ghcr.io/your-github-username/mygram-web:latest

# CI/CD
JENKINS_URL=https://jenkins.example.com
JENKINS_JOB=mygram-fullstack
COOLIFY_APP_URL=https://mygram.example.com
